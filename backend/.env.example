# Backend environment example for local development
# Copy this file to .env and fill values before running locally or in Docker.

# MongoDB connection string. When using docker-compose the host is 'mongo'.

MONGO_URI=mongodb://mongo:27017/jsfitness

# JWT secret for signing access tokens (use a strong, random value in production)
JWT_SECRET=change_this_to_a_strong_random_value

# Optional: JWT token expiry override (e.g. '7d')
ACCESS_TOKEN_EXPIRES=7d

# Server settings
NODE_ENV=development
PORT=5000

# Cookies
# Options: 'lax', 'strict', 'none'
COOKIE_SAMESITE=lax
# If deploying frontend to a domain and backend on a subdomain, set COOKIE_DOMAIN accordingly (e.g. .jsfitness.in)
COOKIE_DOMAIN=

# Allow open registration (set to 'true' temporarily for seeding users, otherwise keep 'false')
ALLOW_REGISTRATION=false

# CORS origin for development (frontend running on localhost:3000)
CORS_ORIGIN=http://localhost:3000

# Optional: Set a secure cookie flag override (true/false). In production NODE_ENV=production implies secure cookies.
COOKIE_SECURE=

# Email Service Settings (e.g., Gmail App Password)
SMTP_USER=jsfitness.management@gmail.com
SMTP_PASS=your_app_password_here
